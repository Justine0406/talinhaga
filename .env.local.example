ANTHROPIC_API_KEY=your_key_here
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ElevenLabs TTS — required for /api/speak. Set a hard spend cap in the
# ElevenLabs dashboard (Settings → Subscription) before enabling in prod.
ELEVENLABS_API_KEY=your_key_here
# Pick a stock voice ID from https://elevenlabs.io/app/voice-library and paste here.
ELEVENLABS_VOICE_ID=your_voice_id_here
# Optional override — defaults to eleven_turbo_v2_5 (faster + cheaper, supports Tagalog).
# Set to eleven_multilingual_v2 if you want premium prosody at ~2x cost.
# ELEVENLABS_MODEL=eleven_turbo_v2_5
